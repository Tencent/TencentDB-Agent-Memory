{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": false,
    "noEmitOnError": true,
    "types": ["node"]
  },
  "include": ["lib/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
